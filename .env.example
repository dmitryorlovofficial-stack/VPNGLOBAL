# VPN Panel — Конфигурация
# Скопируйте в .env и заполните: cp .env.example .env
# Или используйте setup.sh — он сгенерирует .env автоматически

# Панель
PANEL_PORT=9443
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASS=changeme
PANEL_SECRET_KEY=change-me-to-random-64-char-string

# База данных (пароль PostgreSQL)
DB_PASSWORD=change-me-to-random-password

# Telegram бот (опционально)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
